# Copy to .env and fill in. docker-compose reads this file.

# --- Backend ---
HANGAR_HTTP_ADDR=:8080
HANGAR_DATABASE_URL=postgres://hangar:hangar@postgres:5432/hangar?sslmode=disable
HANGAR_DATA_DIR=/data

# Comma-separated allowed CORS origins for the SPA (dev: Nuxt on :3000)
HANGAR_CORS_ORIGINS=http://localhost:3000

# Set false for local plain-HTTP dev so the session cookie is sent over http://
HANGAR_SECURE_COOKIES=false
HANGAR_SESSION_COOKIE_NAME=hangar_session
HANGAR_SESSION_TTL=720h

# 32-byte AES-256 key, base64-std encoded. Generate:
#   openssl rand -base64 32
HANGAR_ENCRYPTION_KEY=

# Telegram application credentials from https://my.telegram.org/apps
HANGAR_TG_API_ID=
HANGAR_TG_API_HASH=

HANGAR_LOG_LEVEL=info

# --- Postgres (docker-compose) ---
POSTGRES_USER=hangar
POSTGRES_PASSWORD=hangar
POSTGRES_DB=hangar

# --- Frontend ---
# Base URL the SPA uses to reach the backend API (browser-visible).
NUXT_PUBLIC_API_BASE=http://localhost:8080
